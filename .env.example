# Copia este archivo a .env y ajusta los valores.
# docker-compose lee .env automaticamente.

# --- Base de datos (PostgreSQL + pgvector) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tesis
# URL que usa el backend dentro de docker-compose (host = nombre del servicio "db").
DATABASE_URL=postgresql://postgres:postgres@db:5432/tesis

# --- Proveedor de LLM ---
LLM_PROVIDER=anthropic            # o: local
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b

# --- Proveedor de embeddings (pieza aparte: Anthropic no genera embeddings) ---
# Decisión del proyecto: embeddings locales con Ollama (gratis y offline).
# Es independiente del LLM: puedes usar Claude (arriba) + Ollama (aquí) a la vez.
EMBEDDING_PROVIDER=local          # o: hosted
EMBEDDING_MODEL_HOSTED=voyage-3
EMBEDDING_MODEL_LOCAL=bge-m3      # multilingüe, 1024 dims (ollama pull bge-m3)
EMBEDDING_DIM=1024                # debe coincidir con el modelo elegido (bge-m3 = 1024)
VOYAGE_API_KEY=                   # solo si usas el proveedor hospedado (Voyage)
# Endpoint local compatible con OpenAI. Desde el contenedor, Ollama (que corre en
# el host) se alcanza por host.docker.internal, no por localhost.
EMBEDDING_LOCAL_BASE_URL=http://host.docker.internal:11434/v1

# --- Frontend ---
# URL del backend vista desde el navegador del usuario.
# (8001 en el host porque 8000 suele estar ocupado; ver docker-compose.yml)
NEXT_PUBLIC_API_URL=http://localhost:8001
